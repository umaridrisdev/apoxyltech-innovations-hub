# Copy this file to .env (backend) and fill in real values.
# .env is gitignored — never commit real secrets.

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Database ---
DATABASE_URL=postgresql+asyncpg://apoxyltech:apoxyltech@db:5432/apoxyltech

# --- Auth / JWT ---
JWT_SECRET_KEY=replace-with-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Redis (optional in Phase 1; only needed for rate limiting at scale) ---
REDIS_URL=redis://redis:6379/0

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=apoxyltech-phase1
R2_PUBLIC_URL_BASE=

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=no-reply@apoxyltech.com

# --- Sentry ---
SENTRY_DSN=

# --- CORS ---
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# --- NDPR retention ---
LEADS_RETENTION_DAYS=365
